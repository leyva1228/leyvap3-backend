# Django
DJANGO_SECRET_KEY=genera-una-clave-nueva-segura-aqui
DJANGO_DEBUG=False

# Base de datos
DB_ENGINE=django.db.backends.mysql
DB_NAME=leyvap3-db
DB_USER=tu_usuario_db
DB_PASSWORD=tu_contraseña_segura
DB_HOST=localhost
DB_PORT=3306

# Railway (completar con la URL real tras deploy)
DJANGO_ALLOWED_HOSTS=.railway.app,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://<tu-dominio>.railway.app
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://<tu-frontend>.railway.app

# Cloudinary (para subida de imágenes persistente - gratis en cloudinary.com)
# CLOUDINARY_CLOUD_NAME=tu-cloud-name
# CLOUDINARY_API_KEY=tu-api-key
# CLOUDINARY_API_SECRET=tu-api-secret

# Render (cuando despliegues aquí)
# Render inyecta DATABASE_URL automáticamente al linkear PostgreSQL
